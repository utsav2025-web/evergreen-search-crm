# ── Application ───────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
SESSION_COOKIE_NAME=sf_session
SESSION_MAX_AGE=2592000  # 30 days in seconds

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./searchfund.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/searchfund

# ── Redis / Celery ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Users (hashed at startup) ─────────────────────────────────────
USER_MATT_PASSWORD=changeme_matt
USER_UTSAV_PASSWORD=changeme_utsav

# ── Google / Gmail OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Scraper Settings ──────────────────────────────────────────────
SCRAPER_DELAY_SECONDS=2
SCRAPER_MAX_RETRIES=3

# ── CORS (Production) ─────────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins (e.g. your Netlify URL)
CORS_ORIGINS_EXTRA=https://your-app.netlify.app
